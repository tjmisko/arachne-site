---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Eyebrow from "../components/Eyebrow.astro";
import Button from "../components/Button.astro";
import Pillar from "../components/Pillar.astro";
import FlowSnippet from "../components/FlowSnippet.astro";
import { type BlockCategory } from "../lib/flow";

const repoUrl = "https://github.com/";

const pillars = [
  {
    eyebrow: "Visible",
    title: "The process is the artifact",
    body: "Every step declared, every connection explicit, the whole flow specified before it runs. You read a map, not a transcript.",
  },
  {
    eyebrow: "Bounded",
    title: "Hard to run off the road",
    body: "Each step runs isolated, with a narrow job and only the information you hand it — so a run has few places it can go wrong. Run it on real data, watch execution move through the graph, and keep a human in the loop wherever a judgment isn't delegable.",
  },
  {
    eyebrow: "Auditable",
    title: "Always reconstructable",
    body: "What ran, what it consumed, what it produced — recorded. Every AI claim traces to its source passage. Provenance is never stripped.",
  },
];

const verifyFlow: { label: string; category: BlockCategory }[] = [
  { label: "Extract Insights", category: "extraction" },
  { label: "Gate", category: "control" },
  { label: "Draft", category: "synthesis" },
];

const sectors = [
  ["Professional & financial services", "Due diligence, underwriting, KYC review, research synthesis."],
  ["Legal & compliance", "Regulatory submissions, contract review, policy monitoring."],
  ["Healthcare administration", "Prior authorization, referral triage, records processing."],
  ["Government & public sector", "Grant applications, permit review, benefits intake."],
  ["Research & intelligence", "Source monitoring, structured findings, report synthesis."],
  ["Operations & procurement", "Vendor onboarding, RFP processing, approval chains."],
];

const notList = [
  ["Not a general-purpose AI agent", "No open-ended autonomous execution. Every step is declared, typed, and inspectable before it runs."],
  ["Not a low-code app builder", "Arachne builds automation flows, not user-facing applications."],
  ["Not a storage system", "It processes and routes data; durable storage is a connector target."],
  ["Not a replacement for judgment", "It routes judgment to the right person at the right time."],
  ["Not code-first", "You wire together blocks that already do most of the work. Custom code is there when you want it — easy to reach, never required."],
];
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <Eyebrow>Automation for knowledge work</Eyebrow>
      <h1 class="display">
        Delegate the by-the-book work to agents — and see exactly what they
        do.
      </h1>
      <p class="lead measure">
        Arachne is two things at once: a visual canvas you build on, and a
        sandboxed runtime that executes it — independent steps running in
        parallel, each one isolated. Hand routine knowledge work to agents and
        see exactly what each one does. Trust the process, not the run: verify
        it once, and you don't have to re-check every run.
      </p>
      <div class="actions">
        <Button href={repoUrl} variant="primary">Get started</Button>
        <Button href="/how-it-works" variant="ghost">See how it works</Button>
      </div>
    </div>
    <div class="container hero-canvas">
      <Hero />
      <p class="desktop-note">A desktop canvas — best explored on a big screen.</p>
    </div>
  </section>

  <!-- THE GAP -->
  <section class="section">
    <div class="container measure">
      <Eyebrow>Run agents you can't trust?</Eyebrow>
      <h2>Trust the process, not the implementer.</h2>
      <p class="stack-p">
        An agent run is a trace — a record of what the implementer happened to
        do this time. Nothing to inspect before it runs, nothing to test after.
        It isn't reproducible, it can't be checked systematically, and the data
        and the logic are tangled together. You're left hoping it got it right.
      </p>
      <p>
        So you don't trust the implementer. You bound it — a narrow job, only
        the information it needs — and you trust the process it runs inside. The
        canvas is where that process is specified and read: visible in the JSON,
        testable before it touches real data, legible in the version history. No
        single step has to carry the trust; the whole, laid out where you can
        see it, does. You verify a run. You trust a flow.
      </p>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="section">
    <div class="container">
      <Eyebrow>Visible · Bounded · Auditable</Eyebrow>
      <h2>Built around what automation gets dangerously wrong, quietly.</h2>
      <div class="grid-3">
        {pillars.map((p) => <Pillar eyebrow={p.eyebrow} title={p.title}>{p.body}</Pillar>)}
      </div>
    </div>
  </section>

  <!-- AGENT BUILDS, HUMAN VERIFIES -->
  <section class="section">
    <div class="container split">
      <div class="measure">
        <Eyebrow>The inversion</Eyebrow>
        <h2>The agent builds the flow. You verify it. Then it runs.</h2>
        <p class="stack-p">
          Coding agents are genuinely good at one thing: building. The mistake
          is handing an agent a hazily specified process and trusting it to
          execute — asking it to be reliable exactly where it isn't. Arachne
          flips the roles. The agent does what it's good at — it builds the
          flow, the way you'd otherwise pay an engineer to — and you do what
          only you can: decide whether the process is right. The agent
          generates; you verify; the flow runs.
        </p>
        <p class="stack-p">
          You rarely know the exact process up front, but you know it when you
          see it. So the real loop is reactive: the agent proposes, you respond,
          it adjusts. That loop is badly captured today — drive an agent from a
          command line and all you get back is a transcript, a record of what it
          happened to do, not a view of whether the process is right. The canvas
          captures the loop instead: the agent's work is laid out where you can
          read it, react to it, and change it — directly, or just by asking.
        </p>
        <p class="stack-p">
          Work however the task wants: delegate a whole flow and verify it, or
          build it block by block alongside the agent. Either way you verify the
          process, not the output of every run — checking on purpose where a
          step needs a human, retrospectively when a result looks wrong and you
          trace it to the block that produced it, and less over time as the
          process learns and earns the trust to let it run unwatched.
        </p>
        <p>
          Humans are first-class participants, not edge cases. A Gate pauses
          execution, routes a structured task to the right person, and resumes
          when they've acted.
        </p>
      </div>
      <div class="snippet-wrap">
        <FlowSnippet nodes={verifyFlow} caption="A Gate holds for human review between extraction and drafting." />
      </div>
    </div>
  </section>

  <!-- THE WEDGE -->
  <section class="section">
    <div class="container measure">
      <Eyebrow>What's different</Eyebrow>
      <h2>Plenty of tools draw the pipeline. Arachne shows the judgment inside it.</h2>
      <p class="stack-p">
        A visual canvas is table stakes — every automation tool has one, and
        they all show you the same thing: the plumbing, what connects to what.
        What they leave as a black box is the step where an agent made a call.
        Arachne makes that step legible — what it saw, what it claimed, and the
        source behind every claim — so the canvas reads as an audit trail for
        the person accountable for the outcome, not just a wiring diagram for
        whoever built it.
      </p>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="section">
    <div class="container">
      <Eyebrow>Who it's for</Eyebrow>
      <h2>If a person is following a script to move information, that should run itself.</h2>
      <p class="measure stack-p">
        By-the-book work — the same steps, the same rules, applied again and
        again. Automatable in principle, but never quite worth an engineer's
        time to build and maintain, so it stays manual. That's the work Arachne
        is for: consistent enough to formalize, high-volume enough to automate,
        and finally cheap enough to bother.
      </p>
      <dl class="grid-3 sectors">
        {sectors.map(([term, desc]) => (
          <div class="sector">
            <dt>{term}</dt>
            <dd>{desc}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- WHAT IT IS NOT -->
  <section class="section">
    <div class="container measure">
      <Eyebrow>What it is not</Eyebrow>
      <h2>It earns trust by refusing scope.</h2>
      <ul class="not-list">
        {notList.map(([term, desc]) => (
          <li>
            <span class="not-term">{term}.</span> {desc}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta">
    <div class="container measure">
      <h2>Leave with the tool, not a credential.</h2>
      <p class="stack-p">
        Arachne is local-first and needs no account for local use. The flows are
        yours, the data is yours, the execution history is yours.
      </p>
      <div class="actions">
        <Button href={repoUrl} variant="primary">Get started</Button>
        <Button href={repoUrl} variant="ghost">View on GitHub</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3.5rem, 8vh, 6rem) var(--section-pad);
  }
  h1.display {
    margin-top: var(--s-16);
    max-width: 20ch;
    /* Long tokens (e.g. "by-the-book") must never push past the viewport on
       narrow phones — break + hyphenate before they overflow. */
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .lead {
    margin-top: var(--s-24);
  }
  /* Mobile-only: the product is a desktop canvas. Land the pitch, signal where
     it lives — not a funnel (DESIGN.md CTA stance). */
  .desktop-note {
    display: none;
    margin-top: var(--s-16);
    font-family: var(--font-mono);
    font-size: var(--ms-small);
    color: var(--fg-3);
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-12);
    margin-top: var(--s-32);
  }
  .hero-canvas {
    margin-top: var(--s-40);
  }

  h2 {
    max-width: 22ch;
  }
  .stack-p {
    margin-bottom: var(--s-16);
  }
  .section p {
    margin-top: var(--s-16);
  }

  .grid-3 {
    margin-top: var(--s-40);
    display: grid;
    gap: var(--s-20);
    grid-template-columns: repeat(3, 1fr);
  }

  .split {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--s-40);
    align-items: center;
  }
  .snippet-wrap {
    background: var(--bg-1);
    border: 1px solid var(--border-0);
    border-radius: var(--r-10);
    padding: var(--s-32) var(--s-24);
  }

  .sectors {
    margin-top: var(--s-32);
  }
  .sector dt {
    font-weight: 600;
    color: var(--fg-0);
  }
  .sector dd {
    margin: var(--s-4) 0 0;
    color: var(--fg-2);
    font-size: var(--ms-small);
  }

  .not-list {
    margin-top: var(--s-24);
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--s-16);
  }
  .not-list li {
    padding-left: var(--s-20);
    position: relative;
    color: var(--fg-2);
    font-size: var(--ms-small);
  }
  .not-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .not-term {
    color: var(--fg-0);
    font-weight: 600;
  }

  .cta {
    background: var(--bg-1);
  }

  @media (max-width: 860px) {
    .grid-3,
    .split {
      grid-template-columns: 1fr;
    }
    .desktop-note {
      display: block;
    }
  }

  /* Small phones: ease the display down a touch so the headline never right-cuts
     the lead and dots below it. */
  @media (max-width: 480px) {
    h1.display {
      font-size: clamp(2rem, 1rem + 6vw, 2.55rem);
    }
  }
</style>
