---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /** Narrow editorial column (Philosophy, blog posts). */
  editorial?: boolean;
}

const {
  title = "Arachne — visible, bounded, auditable automation for knowledge work",
  description = "A visual canvas for building, running, and auditing information-processing pipelines. The agent builds the flow. You verify it. Then it runs.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/og.png", Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0b0d10" />
    <!-- Page is already dark: declare the scheme and tell Dark Reader to stand down. -->
    <meta name="color-scheme" content="dark" />
    <meta name="darkreader-lock" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Arachne"
      href={new URL("/rss.xml", Astro.site).href}
    />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style>
      .skip {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--bg-2);
        color: var(--fg-0);
        padding: var(--s-8) var(--s-12);
        z-index: 100;
        border: 1px solid var(--border-1);
        border-radius: var(--r-6);
      }
      .skip:focus {
        left: var(--s-12);
        top: var(--s-12);
      }
    </style>
  </body>
</html>
