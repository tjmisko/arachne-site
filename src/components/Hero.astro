---
import { categoryVar } from "../lib/flow";
import { FLOWS, ROTATION, type HeroFlow } from "../lib/heroFlows";

/**
 * Rotating execution hero. Each of six domain flows runs a fan-out → fan-in →
 * human-gate pipeline; the timeline holds several branch nodes in RUNNING at
 * once (`Promise.all` over a stage). Clickable domain dots let a visitor jump to
 * their field; a hidden seventh dot reveals the TPS-report easter egg.
 * `prefers-reduced-motion` freezes on the bundled Feedback Synthesis flow — a
 * clean, fully-completed static diagram. Spec: docs/parallel-flow-plan.md.
 */

// Geometry
const NW = 120;
const NH = 58;
const BAR = 5;
const MX = 14;
const GAP = 20;
const MY = 16;
const ROW_GAP = 30;
const ROW_PITCH = NH + ROW_GAP;

function layout(flow: HeroFlow) {
  const maxCol = Math.max(...flow.nodes.map((n) => n.col));
  const vw = MX * 2 + (maxCol + 1) * NW + maxCol * GAP;
  const vh = MY * 2 + flow.maxLane * ROW_PITCH + NH;
  const pos = new Map<string, { x: number; y: number; cx: number; cy: number }>();
  const nodes = flow.nodes.map((n) => {
    const x = MX + n.col * (NW + GAP);
    const y = MY + n.lane * ROW_PITCH;
    const o = { ...n, x, y, cx: x + NW / 2, cy: y + NH / 2 };
    pos.set(n.id, { x, y, cx: o.cx, cy: o.cy });
    return o;
  });
  const edges = flow.edges.map((e, i) => {
    const a = pos.get(e.from)!;
    const b = pos.get(e.to)!;
    const x1 = a.x + NW;
    const y1 = a.cy;
    const x2 = b.x;
    const y2 = b.cy;
    const dx = (x2 - x1) * 0.5;
    return { id: `${flow.id}-e${i}`, from: e.from, d: `M ${x1} ${y1} C ${x1 + dx} ${y1}, ${x2 - dx} ${y2}, ${x2} ${y2}` };
  });
  return { vw, vh, nodes, edges };
}

const LAYOUTS = FLOWS.map((flow) => ({ flow, ...layout(flow) }));

// Client timeline data (kept minimal — markup carries the rest).
const TIMELINES = FLOWS.map((f) => ({
  id: f.id,
  domain: f.domain,
  pattern: f.pattern,
  pain: f.pain,
  gate: f.gate,
  stages: f.stages,
  easterEgg: !!f.easterEgg,
}));

const firstId = ROTATION[0].id;
---

<div class="hero-rot" data-hero>
  <div class="hero-stage-wrap">
    {
      LAYOUTS.map(({ flow, vw, vh, nodes, edges }) => (
        <div class="hero-stage" data-flow={flow.id} style={`--vw: ${vw}`} hidden={flow.id !== firstId}>
          <svg viewBox={`0 0 ${vw} ${vh}`} role="img" aria-label={flow.aria} preserveAspectRatio="xMidYMid meet">
            <defs>
              <marker
                id={`arrow-${flow.id}`}
                viewBox="0 0 8 8"
                refX="6"
                refY="4"
                markerWidth="6"
                markerHeight="6"
                orient="auto-start-reverse"
              >
                <path d="M1,1 L6,4 L1,7" fill="none" stroke="currentColor" stroke-width="1.4" />
              </marker>
            </defs>

            {edges.map((e) => (
              <path class="edge" id={e.id} data-from={e.from} d={e.d} marker-end={`url(#arrow-${flow.id})`} />
            ))}

            {nodes.map((n) => (
              <g class="node" data-node={n.id} data-error={n.errorStatus ?? undefined} style={`--tint: ${categoryVar[n.cat]}`}>
                <rect class="ring" x={n.x - 4} y={n.y - 4} width={NW + 8} height={NH + 8} rx="11" />
                <rect class="body" x={n.x} y={n.y} width={NW} height={NH} rx="8" />
                <rect class="bar" x={n.x} y={n.y} width={NW} height={BAR + 4} rx="8" />
                <rect class="bar-clip" x={n.x} y={n.y + BAR} width={NW} height={6} />
                <text class="label" x={n.cx} y={n.y + 28} text-anchor="middle">
                  {n.label}
                </text>
                <text class="status" x={n.cx} y={n.y + 45} text-anchor="middle">
                  IDLE
                </text>
                {n.id === flow.gate && <path class="tick" d={`M ${n.cx - 7} ${n.y + 44} l 4 4 l 8 -9`} />}
              </g>
            ))}
          </svg>
        </div>
      ))
    }
  </div>

  <p class="hero-pain" data-pain>{ROTATION[0].pain}</p>

  <div class="hero-foot">
    <div class="hero-dots" role="group" aria-label="Choose a workflow by domain">
      {
        ROTATION.map((f, i) => (
          <button
            class={`hero-dot${i === 0 ? " is-active" : ""}`}
            type="button"
            data-dot={f.id}
            aria-current={i === 0 ? "true" : "false"}
            aria-label={`${f.domain} — ${f.pattern}`}
          >
            {f.domain}
          </button>
        ))
      }
      <button class="hero-dot hero-dot--egg" type="button" data-dot="tps-reports" aria-label="TPS reports (easter egg)">🖇</button>
    </div>
    <p class="hero-caption">Independent steps run in parallel — each isolated.</p>
  </div>

  <p class="sr-only" aria-live="polite" data-live></p>

  <script id="hero-data" type="application/json" set:html={JSON.stringify(TIMELINES)} is:inline></script>
</div>

<style>
  .hero-rot {
    width: 100%;
    /* Mobile node scale: rendered node ≈ NW × this. 0.9 ≈ 108px — legible mono
       labels while fitting the two-lane fan in portrait. Tune here. */
    --node-scale: 0.9;
  }
  .hero-stage-wrap {
    width: 100%;
  }
  .hero-stage[hidden] {
    display: none;
  }
  svg {
    display: block;
    width: 100%;
    height: auto;
    color: var(--border-1); /* arrowhead currentColor */
    overflow: visible;
  }

  /* ── nodes ──────────────────────────────────────────────────────────── */
  .body {
    fill: var(--bg-2);
    stroke: var(--border-1);
    stroke-width: 1;
  }
  .bar {
    fill: var(--tint);
    opacity: 0.85;
  }
  .bar-clip {
    fill: color-mix(in srgb, var(--tint) 16%, var(--bg-2));
  }
  .label {
    fill: var(--fg-0);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
  }
  .status {
    fill: var(--fg-3);
    font-family: var(--font-mono);
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: 0.4px;
  }

  /* ── edges ──────────────────────────────────────────────────────────── */
  .edge {
    fill: none;
    stroke: var(--border-0);
    stroke-width: 1.4;
    transition: stroke var(--t-slow);
  }
  .edge.lit {
    stroke: color-mix(in srgb, var(--accent) 60%, var(--border-1));
  }
  .edge.flowing {
    stroke: var(--accent-strong);
    stroke-dasharray: 5 7;
    animation: flow 0.7s linear infinite;
  }
  @keyframes flow {
    to {
      stroke-dashoffset: -12;
    }
  }

  /* ── run states ─────────────────────────────────────────────────────── */
  .ring {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.5;
    opacity: 0;
    transition: opacity var(--t-medium);
  }
  .node.needs-input .ring {
    opacity: 0.9;
    animation: ringpulse 1.6s ease-in-out infinite;
  }
  @keyframes ringpulse {
    50% {
      opacity: 0.35;
    }
  }
  .node.running .bar {
    opacity: 1;
    animation: barpulse 1.4s ease-in-out infinite;
  }
  .node.running .body {
    stroke: color-mix(in srgb, var(--accent-strong) 50%, var(--border-1));
  }
  @keyframes barpulse {
    50% {
      opacity: 0.45;
    }
  }
  .node.running .status {
    fill: var(--accent-strong);
  }
  .node.completed .status {
    fill: var(--success);
  }
  .node.completed .body {
    stroke: color-mix(in srgb, var(--success) 35%, var(--border-1));
  }
  .node.needs-input .status {
    fill: var(--conf-needs-input);
  }

  .tick {
    fill: none;
    stroke: var(--success);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0;
    transition: opacity var(--t-fast);
  }
  .node.approved .tick {
    opacity: 1;
  }
  .node.approved .status {
    opacity: 0;
  }

  /* ── pain line + footer chrome ──────────────────────────────────────── */
  .hero-pain {
    margin: var(--s-16) 0 0;
    font-size: var(--ms-small);
    color: var(--fg-2);
    font-style: italic;
    min-height: 2.6em;
  }

  .hero-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-12);
    margin-top: var(--s-16);
    padding-top: var(--s-12);
    border-top: 1px solid var(--border-0);
  }
  .hero-dots {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-8);
  }
  .hero-dot {
    font-family: var(--font-mono);
    font-size: var(--fs-12);
    font-weight: 700;
    color: var(--fg-3);
    background: transparent;
    border: 1px solid var(--border-1);
    border-radius: var(--r-6);
    padding: var(--s-8) var(--s-12);
    cursor: pointer;
    transition:
      color var(--t-fast),
      border-color var(--t-fast),
      background var(--t-fast);
  }
  .hero-dot:hover {
    color: var(--fg-1);
    border-color: var(--border-1);
  }
  .hero-dot.is-active {
    color: var(--fg-0);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border-1));
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-2));
  }
  .hero-dot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .hero-dot--egg {
    padding: var(--s-8) var(--s-12);
    opacity: 0.45;
    font-size: var(--ms-small);
  }
  .hero-dot--egg:hover {
    opacity: 1;
  }

  .hero-caption {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--ms-small);
    color: var(--fg-3);
    text-align: right;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 860px) {
    .hero-caption {
      text-align: left;
      width: 100%;
    }

    /* Mobile hero = horizontal scroll-follow window. Keep nodes at a legible
       fixed size (wider than the viewport) and let the flow overflow, instead
       of shrinking the whole DAG to fit. The visible stage is the scroll
       viewport; the SVG width is derived from its own viewBox (--vw). The
       script auto-pans this container to track the running stage. LTR is
       load-bearing — never stack the flow vertically. */
    .hero-stage-wrap {
      position: relative;
    }
    .hero-stage {
      overflow-x: auto;
      overflow-y: hidden;
      overscroll-behavior-x: contain;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none; /* edge fades carry the scroll affordance */
    }
    .hero-stage::-webkit-scrollbar {
      display: none;
    }
    .hero-stage svg {
      /* Override the global `svg { max-width: 100% }` reset so the flow can
         exceed the viewport and scroll, instead of shrinking to fit. */
      max-width: none;
      width: calc(var(--vw) * var(--node-scale) * 1px);
    }

    /* Edge fades hint there's more flow off-screen; the script toggles
       can-left / can-right from the live scroll position. */
    .hero-stage-wrap::before,
    .hero-stage-wrap::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: 32px;
      pointer-events: none;
      z-index: 2;
      opacity: 0;
      transition: opacity var(--t-medium);
    }
    .hero-stage-wrap::before {
      left: 0;
      background: linear-gradient(to right, var(--bg-0), transparent);
    }
    .hero-stage-wrap::after {
      right: 0;
      background: linear-gradient(to left, var(--bg-0), transparent);
    }
    .hero-stage-wrap.can-left::before {
      opacity: 1;
    }
    .hero-stage-wrap.can-right::after {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .edge,
    .ring,
    .bar {
      animation: none !important;
    }
  }
</style>

<script>
  interface Timeline {
    id: string;
    domain: string;
    pattern: string;
    pain: string;
    gate: string;
    stages: string[][];
    easterEgg: boolean;
  }

  const root = document.querySelector<HTMLElement>("[data-hero]");
  const dataEl = document.getElementById("hero-data");

  if (root && dataEl) {
    const TIMELINES: Timeline[] = JSON.parse(dataEl.textContent || "[]");
    const byId = new Map(TIMELINES.map((t) => [t.id, t] as const));
    const rotation = TIMELINES.filter((t) => !t.easterEgg);

    const stages = Array.from(root.querySelectorAll<HTMLElement>(".hero-stage"));
    const stageEl = (id: string) => stages.find((s) => s.dataset.flow === id)!;
    const painEl = root.querySelector<HTMLElement>("[data-pain]");
    const liveEl = root.querySelector<HTMLElement>("[data-live]");
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>(".hero-dot"));

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

    const BASE = 950;
    const GATEMS = 1800;
    const SETTLE = 1500;
    const PAN_MS = 800; // eased follow-slide duration (mobile scroll-follow)
    const LINGER_MS = 600; // dwell centered after the camera arrives, before completing

    const nodeEl = (flowEl: HTMLElement, id: string) => flowEl.querySelector<SVGGElement>(`[data-node="${id}"]`);

    // ── Mobile scroll-follow window ───────────────────────────────────────
    // At ≤860px each stage is a horizontal scroll viewport (see styles): nodes
    // stay legible and the flow overflows. Pan the viewport to keep the running
    // stage centered, reinforcing the left-to-right reading. All no-ops on
    // desktop, where the container isn't scrollable.
    const stageWrap = root.querySelector<HTMLElement>(".hero-stage-wrap");
    const FOLLOW_COOLDOWN = 4000;
    let lastUserScroll = -Infinity;
    const userScrolling = () => performance.now() - lastUserScroll < FOLLOW_COOLDOWN;
    const scrollable = (el: HTMLElement) => el.scrollWidth - el.clientWidth > 1;
    // True when this is a live mobile scroll-follow render (drives the slower,
    // linger-friendly pacing). Independent of the user-gesture cooldown.
    const followMode = (el: HTMLElement) => !reduce && scrollable(el);

    // The follow-pan is a deliberate, eased slide — not the browser's quick
    // native smooth-scroll — so it reads clearly as the camera tracking
    // execution. Slow enough to watch; cancelable by a new pan or a takeover.
    const easeInOutCubic = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);
    let panFrame = 0;
    const cancelPan = () => {
      if (panFrame) cancelAnimationFrame(panFrame);
      panFrame = 0;
    };
    const animatePan = (el: HTMLElement, to: number) => {
      cancelPan();
      const from = el.scrollLeft;
      const dist = to - from;
      if (Math.abs(dist) < 2) return;
      const start = performance.now();
      const step = (now: number) => {
        const p = Math.min(1, (now - start) / PAN_MS);
        el.scrollLeft = from + dist * easeInOutCubic(p);
        panFrame = p < 1 ? requestAnimationFrame(step) : 0;
      };
      panFrame = requestAnimationFrame(step);
    };

    const updateFades = (flowEl: HTMLElement) => {
      if (!stageWrap) return;
      const max = flowEl.scrollWidth - flowEl.clientWidth;
      stageWrap.classList.toggle("can-left", max > 1 && flowEl.scrollLeft > 1);
      stageWrap.classList.toggle("can-right", max > 1 && flowEl.scrollLeft < max - 1);
    };

    const followColumn = (flowEl: HTMLElement, id: string) => {
      if (reduce || !scrollable(flowEl) || userScrolling()) return;
      const node = nodeEl(flowEl, id);
      if (!node) return;
      // SVG children have no offsetLeft — measure against the container instead.
      const cRect = flowEl.getBoundingClientRect();
      const nRect = node.getBoundingClientRect();
      const max = flowEl.scrollWidth - flowEl.clientWidth;
      const target = flowEl.scrollLeft + (nRect.left - cRect.left) + nRect.width / 2 - flowEl.clientWidth / 2;
      animatePan(flowEl, Math.max(0, Math.min(max, target)));
    };

    // Genuine user intent (these don't fire from a programmatic scrollTo) pauses
    // auto-follow briefly so a manual swipe isn't fought; the scroll listener
    // keeps the edge fades in sync with the live position.
    const markUser = () => {
      lastUserScroll = performance.now();
      cancelPan(); // a real swipe/tap takes over immediately
    };
    ["pointerdown", "touchstart", "wheel"].forEach((ev) =>
      stageWrap?.addEventListener(ev, markUser, { passive: true }),
    );
    stages.forEach((s) => s.addEventListener("scroll", () => updateFades(s), { passive: true }));
    window.addEventListener("resize", () => {
      const visible = stages.find((s) => !s.hidden);
      if (visible) updateFades(visible);
    });

    const setNode = (flowEl: HTMLElement, id: string, state: string, label: string) => {
      const n = nodeEl(flowEl, id);
      if (!n) return;
      n.classList.remove("running", "completed", "needs-input", "approved");
      if (state) n.classList.add(state);
      const s = n.querySelector<SVGTextElement>(".status");
      if (s) s.textContent = label;
    };

    const lightEdges = (flowEl: HTMLElement, id: string, flowing: boolean) => {
      flowEl.querySelectorAll<SVGPathElement>(`.edge[data-from="${id}"]`).forEach((e) => {
        e.classList.toggle("flowing", flowing);
        e.classList.toggle("lit", !flowing);
      });
    };

    const advance = async (flowEl: HTMLElement, id: string, ms: number) => {
      const n = nodeEl(flowEl, id);
      const err = n?.getAttribute("data-error");
      setNode(flowEl, id, "running", "RUNNING");
      followColumn(flowEl, id);
      // In scroll-follow mode, hold the step running long enough that it stays
      // visibly working after the ~800ms slide settles (glide, then linger).
      // Desktop isn't scrollable → runMs === ms, so its pacing is unchanged.
      const runMs = followMode(flowEl) ? Math.max(ms, PAN_MS + LINGER_MS) : ms;
      if (err) {
        await sleep(runMs * 0.5);
        const s = n!.querySelector<SVGTextElement>(".status");
        if (s) s.textContent = err; // easter egg: flash the error mid-run
        await sleep(runMs * 0.5);
      } else {
        await sleep(runMs);
      }
      setNode(flowEl, id, "completed", "COMPLETED");
      lightEdges(flowEl, id, true);
      await sleep(520);
      lightEdges(flowEl, id, false);
    };

    const gate = async (flowEl: HTMLElement, id: string, ms: number) => {
      setNode(flowEl, id, "needs-input", "NEEDS-INPUT");
      followColumn(flowEl, id);
      await sleep(ms);
      nodeEl(flowEl, id)?.classList.add("approved");
      await sleep(480);
      setNode(flowEl, id, "completed", "COMPLETED");
      lightEdges(flowEl, id, true);
      await sleep(520);
      lightEdges(flowEl, id, false);
    };

    const reset = (flowEl: HTMLElement) => {
      flowEl.querySelectorAll<SVGGElement>("[data-node]").forEach((n) => {
        n.classList.remove("running", "completed", "needs-input", "approved");
        const s = n.querySelector<SVGTextElement>(".status");
        if (s) s.textContent = "IDLE";
      });
      flowEl.querySelectorAll(".edge").forEach((e) => e.classList.remove("lit", "flowing"));
    };

    const paintComplete = (flowEl: HTMLElement) => {
      flowEl.querySelectorAll<SVGGElement>("[data-node]").forEach((n) => {
        n.classList.remove("running", "needs-input", "approved");
        n.classList.add("completed");
        const s = n.querySelector<SVGTextElement>(".status");
        if (s) s.textContent = "COMPLETED";
      });
      flowEl.querySelectorAll(".edge").forEach((e) => e.classList.add("lit"));
    };

    const showFlow = (id: string) => {
      stages.forEach((s) => (s.hidden = s.dataset.flow !== id));
      const t = byId.get(id);
      if (painEl && t) painEl.textContent = t.pain;
      dots.forEach((d) => {
        const on = d.dataset.dot === id;
        d.setAttribute("aria-current", on ? "true" : "false");
        d.classList.toggle("is-active", on);
      });
      if (liveEl && t) liveEl.textContent = `${t.domain}: ${t.pattern}`;
      // Each flow starts at its left edge — preserve the LTR reading start.
      const active = stageEl(id);
      cancelPan(); // don't let an in-flight tween fight the reset
      active.scrollLeft = 0;
      updateFades(active);
    };

    if (reduce) {
      // Static freeze on the bundled Feedback Synthesis; dots browse statically.
      const frozen = byId.has("feedback-synthesis") ? "feedback-synthesis" : rotation[0].id;
      showFlow(frozen);
      paintComplete(stageEl(frozen));
      dots.forEach((d) =>
        d.addEventListener("click", () => {
          const id = d.dataset.dot!;
          showFlow(id);
          paintComplete(stageEl(id));
        }),
      );
    } else {
      let selected: string | null = null;
      let auto = 0;
      let gen = 0;
      const interrupted = (g: number) => g !== gen;

      const runStage = (flowEl: HTMLElement, ids: string[], ms: number, gateId: string) =>
        Promise.all(ids.map((id) => (id === gateId ? gate(flowEl, id, ms) : advance(flowEl, id, ms))));

      const runFlow = async (t: Timeline, g: number) => {
        const flowEl = stageEl(t.id);
        reset(flowEl);
        await sleep(420);
        for (const st of t.stages) {
          if (interrupted(g)) return;
          const ms = st.includes(t.gate) ? GATEMS : BASE;
          await runStage(flowEl, st, ms, t.gate);
        }
      };

      dots.forEach((d) =>
        d.addEventListener("click", () => {
          const id = d.dataset.dot!;
          selected = selected === id ? null : id; // click active dot again → resume auto
          gen++; // interrupt the in-flight run
          showFlow(selected ?? rotation[auto].id);
        }),
      );

      const dotsWrap = root.querySelector<HTMLElement>(".hero-dots");
      dotsWrap?.addEventListener("keydown", (e) => {
        const i = dots.indexOf(document.activeElement as HTMLButtonElement);
        if (i < 0 || (e.key !== "ArrowRight" && e.key !== "ArrowLeft")) return;
        e.preventDefault();
        const ni = (i + (e.key === "ArrowRight" ? 1 : dots.length - 1)) % dots.length;
        dots[ni].focus();
      });

      (async () => {
        // eslint-disable-next-line no-constant-condition
        while (true) {
          const g = gen;
          const t = selected ? byId.get(selected)! : rotation[auto];
          showFlow(t.id);
          await runFlow(t, g);
          if (interrupted(g)) continue;
          await sleep(SETTLE);
          if (interrupted(g)) continue;
          if (!selected) auto = (auto + 1) % rotation.length;
        }
      })();
    }
  }
</script>
